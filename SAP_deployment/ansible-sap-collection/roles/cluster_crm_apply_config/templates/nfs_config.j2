{#
  include common header to define nodes and STONITH approach
#}
{% include 'base_config.j2' %}

{#
    Add required primitives for each individual share
#}
{% for share in shares %}
primitive drbd_{{ share.ref}}_nfs \
  ocf:linbit:drbd \
  params drbd_resource="{{ share.ref }}-nfs" \
  op monitor interval="15" role="Master" \
  op monitor interval="30" role="Slave"

ms ms-drbd_{{ share.ref }}_nfs drbd_{{ share.ref }}_nfs \
  meta master-max="1" master-node-max="1" clone-max="2" \
  clone-node-max="1" notify="true" interleave="true"

primitive fs_{{ share.ref }}_sapmnt \
  ocf:heartbeat:Filesystem \
  params device=/dev/drbd{{ share.drbd_num }} \
  directory={{ share.mount }}  \
  fstype={{ share.fstype | default('xfs') }} \
  op monitor interval="10s"

primitive exportfs_{{ share.ref }} \
  ocf:heartbeat:exportfs \
  params directory="{{ share.mount }}" \
  options="rw,no_root_squash,crossmnt" clientspec="*" fsid={{ share.fsid }} wait_for_leasetime_on_stop=true op monitor interval="30s"

{#
    Add load balancer primitives
#}
primitive nc_{{ share.ref }}_nfs azure-lb \
  port={{ share.lb_port }}

primitive vip_{{ share.ref }}_nfs IPaddr2 \
  params ip={{ share.ip }} cidr_netmask=32 \
  op monitor interval=10 timeout=20

group g-{{ share.ref }}_nfs \
  fs_{{ share.ref }}_sapmnt exportfs_{{ share.ref }} nc_{{ share.ref }}_nfs vip_{{ share.ref }}_nfs

order o-{{ share.ref }}_drbd_before_nfs inf: \
  ms-drbd_{{ share.ref }}_nfs:promote g-{{ share.ref }}_nfs:start

colocation col-{{ share.ref }}_nfs_on_drbd inf: \
  g-{{ share.ref }}_nfs ms-drbd_{{ share.ref }}_nfs:Master
{% endfor %}

{#
    Add additional base NFS primitives
#}
primitive nfsserver systemd:nfs-server \
  op monitor interval="30s"

clone cl-nfsserver nfsserver

{#
    Add standard resource defaults
#}
rsc_defaults resource-stickiness="200"