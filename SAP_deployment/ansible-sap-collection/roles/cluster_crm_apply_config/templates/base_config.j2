{#
  Select STONITH strategy
#}
{% if stonith_type == "gcp" %}
{% for node in [node1,node2]  %}
{# GCP STONITH #}
primitive stonith-{{ node }} stonith:external/gcpstonith \
  op monitor interval=300s timeout=60s on-fail=restart \
  op start interval=0 timeout=60s onfail=restart \
  params instance_name={{ node }} \
  gcloud_path="/usr/bin/gcloud" \
  logging=yes

location loc_stonith_{{ node }} stonith-{{ node }} -inf: {{ node }}
{% endfor %}
{% elif stonith_type == "sbd" %}

{# Traditional SBD STONITH #}
primitive stonith-sbd stonith:external/sbd \
    params pcmk_delay_max="15" op monitor interval="15" timeout="15"

{% elif stonith_type == "azure_fence_agent" %}      

primitive rsc_st_azure stonith:fence_azure_arm \
    params subscriptionId={{ subscription_id }} resourceGroup={{ resource_group }} tenantId={{ tenant_id }} login={{ app_id }} passwd={{ app_pass }} \ 
    pcmk_monitor_retries=4 pcmk_action_limit=3 power_timeout=240 pcmk_reboot_timeout=900 \ 
    op monitor interval=3600 timeout=120

{% elif stonith_type == "aws" %}
{# AWS STONITH #}
primitive res_AWS_STONITH stonith:external/ec2 \
	op start interval=0 timeout=180 \
	op stop interval=0 timeout=180 {% if group_names != 'db' %} \
	op monitor interval=120 {% else %} \
  op monitor interval=300 {% endif %} timeout=60 \
	meta target-role=Started \
	params tag={{ key_name }} profile=cluster pcmk_delay_max=15

{% endif %}

{#
  Add Azure events check if we are running on Azure 
#}
{% if platform == "azure" %}
primitive rsc_azure-events ocf:heartbeat:azure-events op monitor interval=10s
clone cln_azure-events rsc_azure-events
{% endif %}