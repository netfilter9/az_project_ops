###     BWIntegrator
###     BODIIntegrators
###     CWMIntegrators
###     RDBMSIntegrators
###     HANAIntegrators
###     ExcelIntegrator
###     SAPEccIntegrator
###     HDPIntegrator
###     RedshiftIntegrator

features={{ feature | default('WebTier,TaskServer,DataReviewTaskJobServer,SearchServer,ApplicationService,CPBServices,CpData,DataReviewService,ISServices,B
OEIntegrator,BWIntegrator,BODIIntegrators,CWMIntegrators,RDBMSIntegrators,HANAIntegrators,ExcelIntegrator,SAPEccIntegrator,HDPIntegra
tor,RedshiftIntegrator,Integrators,root') }}


