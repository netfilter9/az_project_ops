{%- set ns = namespace(servernode_port_is='') %}
{% for i in sap.db.tenants %}
{% if  bods.is.dbserver ==  i  %}
{%- set ns.servernode_port_is = '3'+sap.instance_numbers.db+'41' %}
{% endif %}
{% endfor %}
{% if bods.is.dbserver == sap.db.sid %}
{%- set ns.servernode_port_is = '3'+sap.instance_numbers.db+'15' %}
{% elif  bods.is.dbserver == "SYSTEMDB" %}
{%- set ns.servernode_port_is = '3'+sap.instance_numbers.db+'13' %}
{% endif %}
[{{ is_dsnname }}]
DRIVER=/usr/sap/hdbclient/libodbcHDB.so
SERVERNODE= {{ sap.logical_hosts.db.hostname | default (ansible_hostname) }}:{{ ns.servernode_port_is }}
DATABASENAME= {{ bods.is.dbserver }} 
DESCRIPTION=ISDB   
