    ] 
%}
|{{ row | join('|') }}|
{% endif %}
{% endif %}
{% if output_diskutil.stdout == '' %}
{% set row = [ 
  ansible_hostname,
  sid ,
  "Infra",
  "Checking filesystem utilisation above 80%",
  "None of the Disks are utilized above 80%",
  "<80%"
  ] 
%}
|{{ row | join('|') }}|
{% else %}
{% set row = [ 
  ansible_hostname,
  sid ,
  "Infra",
  "Checking filesystem utilisation above 80%",
  output_diskutil.stdout,
  "<80%"
  ] 
%}
|{{ row | join('|') }}|
{% endif %}
{% if output_hostname.stdout > '13' %}
{% set row = [ 
  ansible_hostname,
  sid ,
  "Infra",
  "Checking if length of  hostname is more than 13",
  output_hostname.stdout,
  "hostname length shouble be <13"
  ] 
%}
|{{ row | join('|') }}|
{% else %}
{% set row = [ 
  ansible_hostname,
  sid ,
  "Infra",
  "Checking if length of  hostname is more than 13",
  output_hostname.stdout,
  "hostname length shouble be <13"
  ] 
%}
|{{ row | join('|') }}|
{% endif %}
