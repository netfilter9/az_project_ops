{%- if sap.db.tenants is defined %}
{%- set ns = namespace(servernode_port_ds='') %}
{% for i in sap.db.tenants %}
{% if  bods.ds.dbserver ==  i  %}
{%- set ns.servernode_port_ds = '3'+sap.instance_numbers.db+'41' %}
{% endif %}
{% endfor %}
{% if bods.ds.dbserver == sap.db.sid %}
{%- set ns.servernode_port_ds = '3'+sap.instance_numbers.db+'15' %}
{% elif  bods.ds.dbserver == "SYSTEMDB" %}
{%- set ns.servernode_port_ds = '3'+sap.instance_numbers.db+'13' %}
{% endif %}
{%- endif %}

[General]
### *** property.ChooseSLDIntegration.description ***
choosesldintegration=nointegrate   

### #property.CMSAuthMode.description#
dscmsauth=Enterprise

### CMS administrator password
dscmspassword={{ passwords.cmsadmin | default(passwords.master) }}

### #property.CMSServerName.description#
dscmssystem={{ CMS_Server | default(ansible_hostname) }}:{{ bods.ds.ports.cmsport | default('6400') }}

### #property.CMSUser.description#
dscmsuser=Administrator

### #property.DSConfigCMSSelection.description#
dsconfigcmsselection=install

### #property.DSHANAJDBCOption.description#
dshanajdbcoption=bundle

### #property.DSInstallTypeSelection.description#
dsinstalltypeselection=Express

### #property.DSRepoCreateUpgrade.description#
dsrepocreateupgrade=create

{% if dbtype == "sybase" %}
### #property.DSRepoDBHost.description#
dsrepodbhost={{sap.db.sid}}

### #property.DSRepoDBName.description#
dsrepodbname={{sap.db.sid}}CMS

### #property.DSRepoDBPort.description#
dsrepodbport=3{{ sap.instance_numbers.db }}13

### #property.EIMDBENV.description#
eimdbenv=/sybase/{{sap.db.sid}}

### property eimsybaseocs
eimsybaseocs=OCS-16_0

### #property.DSRepoDBUser.description#
dsrepodbuser=sa

{% elif dbtype == "hana" %}
### #property.DSRepoDBHost.description#
dsrepodbhost= {{ bods.ds.dsnname | default (default_ds_dsnname) }}

### #property.DSRepoDBPort.description#
dsrepodbport={{ ns.servernode_port_ds }}

### #property.DSRepoDBVersion.description#
dsrepodbversion=2

### #property.DSRepoDBVersionStr.description#
dsrepodbversionstr=HANA 2.X

### #property.EIMDBENV.description#
eimdbenv=/usr/sap/hdbclient/libodbcHDB.so

### #property.DSRepoDBUser.description#
dsrepodbuser={{ bods.ds.dbuser | default('SYSTEM') }}   
{% endif %}

### #property.DSRepoDBPasswd.description#
dsrepodbpasswd={{ passwords.dsrepodbuser | default(passwords.master) }}

### #property.DSRepoDBType.description#
dsrepodbtype={{ dbtype | upper }}

### #property.DSRepoHostMachine.description#
dsrepohostmachine={{ sap.logical_hosts.db.hostname | default (ansible_hostname) }}

### #property.DSRepoNameForCMS.description#
dsreponameforcms=Repo_{{ ansible_hostname }}

### Keycode for the product.
productkey={{ passwords.dsproductkey | default('CA318-902HU3G-00MVX4X-NH7U') }}

### Installation folder for SAP products								
installdir={{ DS_dir }}	   

requiredspace={{ requiredspace | default('7723') }}

### *** property.SelectedLanguagePacks.description ***
selectedlanguagepacks=en

