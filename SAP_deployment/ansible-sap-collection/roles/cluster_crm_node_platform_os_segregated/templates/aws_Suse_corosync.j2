#please read the corosync.conf.5 manual page
totem {
version: 2
token: 30000
consensus: 36000
{% if cluster_type == "hana" %}
token_retransmits_before_loss_const: 6
crypto_cipher: none
crypto_hash: none
{% elif cluster_type == "ascs_sap" %}
token_retransmits_before_loss_const: 10
max_messages: 20
crypto_cipher: aes256
crypto_hash: sha1
{% endif %}
clear_node_high_bit: yes
rrp_mode: passive 
token_retransmits_before_loss_const: 10
secauth: on
crypto_cipher: aes256
crypto_hash: sha1
clear_node_high_bit: yes
interface {
ringnumber: 0
{% if ansible_hostname == node1 %}
bindnetaddr: {{ primary_ip }}
{% elif ansible_hostname == node2 %}
bindnetaddr: {{ secondary_ip }}
{% endif %}

mcastport: 5405
ttl: 1
}
transport: udpu
}
logging {
fileline: off
to_logfile: yes
to_syslog: yes
logfile: /var/log/cluster/corosync.log
debug: off
timestamp: on
logger_subsys {
subsys: QUORUM
debug: off
}
}
nodelist {
node {
ring0_addr: {{ primary_ip }}
nodeid: 1
}
node {
ring0_addr: {{ secondary_ip }}
nodeid: 2
}
}
quorum {
# Enable and configure quorum subsystem (default: off)
# see also corosync.conf.5 and votequorum.5
provider: corosync_votequorum
expected_votes: 2
two_node: 1
}
