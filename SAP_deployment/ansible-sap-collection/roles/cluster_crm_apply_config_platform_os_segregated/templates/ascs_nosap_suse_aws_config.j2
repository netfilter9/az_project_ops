{# 
  create a local variables for the SAP instance references 
  e.g. A4H_ASCS00, A4H_ERS01
#}
{% set ascs_instance = sap.sid + "_" + sap.ascs_type + sap.instance_numbers.ascs %}
{% set ers_instance = sap.sid + "_ERS" + sap.instance_numbers.ers %}

{#
  Select STONITH strategy
#}
{# AWS STONITH #}
primitive res_AWS_STONITH stonith:external/ec2 \
	op start interval=0 timeout=180 \
	op stop interval=0 timeout=180 {% if cluster_type == 'hana' %} \
  op monitor interval=120 timeout=60 \
  meta target-role=Started \
  params tag={{ key_name }} profile=cluster pcmk_delay_max=45	
  {% elif cluster_type == 'db2' %} \
  op monitor interval=180s timeout=60s \
  params tag={{ key_name }} profile=cluster pcmk_delay_max=30
  {% else %} \
    {% if sap.enq_architecture == 'ENSA1'%}
    op monitor interval=180 timeout=60 \
    params tag={{ key_name }} profile=cluster pcmk_delay_max=30
    {%else%}
    op monitor interval=180 timeout=60 \
    params tag={{ key_name }} profile=cluster pcmk_delay_max=10
	{% endif %}

primitive rsc_ip_{{ ascs_instance }} ocf:heartbeat:aws-vpc-move-ip \
  params ip={{ ascs_overlay_ip }} routing_table={{ route_table_id }} \
  interface=eth0 profile=cluster \
  {% if vpc_type is defined and vpc_type == "shared" %}
  routing_table_role="arn:aws:iam::{{ vpc_account_number }}:role/{{ vpc_account_cluster_role }}" \
  lookup_type=NetworkInterfaceId \
  {% endif %}
  op start interval=0 timeout=180 \
  op stop interval=0 timeout=180 \
  op monitor interval=20 timeout=40

primitive rsc_ip_{{ ers_instance }} ocf:heartbeat:aws-vpc-move-ip \
  params ip={{ ers_overlay_ip }} routing_table={{ route_table_id }} \
  interface=eth0 profile=cluster \
  {% if vpc_type is defined and vpc_type == "shared" %}
  routing_table_role="arn:aws:iam::{{ vpc_account_number }}:role/{{ vpc_account_cluster_role }}" \
  lookup_type=NetworkInterfaceId \
  {% endif %}
  op start interval=0 timeout=180 \
  op stop interval=0 timeout=180 \
  op monitor interval=20 timeout=40

{#
    set up file system failover if using traditional NFS or ANF
#}

{% set ascs_device = sap.nfs.ascs_device %}
{% set ers_device = sap.nfs.ers_device %}

{#
    set up file system failover using EFS
#}
primitive rsc_fs_{{ ascs_instance }} ocf:heartbeat:Filesystem \
params device="{{ ascs_device }}" \
directory="/usr/sap/{{ sap.sid|upper }}/{{ sap.ascs_type }}{{ sap.instance_numbers.ascs }}" \
fstype="nfs4" \
options="rsize=1048576,wsize=1048576,hard,timeo=600,retrans=2" \
op start timeout=60s interval=0 \
op stop timeout=60s interval=0 \
op monitor interval=20s timeout=40s


primitive rsc_fs_{{ ers_instance }} ocf:heartbeat:Filesystem \
params device="{{ ers_device }}" \
directory="/usr/sap/{{ sap.sid|upper }}/ERS{{ sap.instance_numbers.ers }}" \
fstype=nfs4 \
options="rsize=1048576,wsize=1048576,hard,timeo=600,retrans=2" \
op start timeout=60s interval=0 \
op stop timeout=60s interval=0 \
op monitor interval=20s timeout=40s

{# 
    set up groups
#}
group SAP-{{ ascs_instance }} \
{% if sap.nfs is defined %}
  fs_{{ ascs_instance }} \
{% endif %}
  nc_{{ ascs_instance }} \
  vip_{{ ascs_instance }} \
  meta resource-stickiness=3000

group SAP-{{ ers_instance }} \
{% if sap.nfs is defined %}
  fs_{{ ers_instance }} \
{% endif %}
  nc_{{ ers_instance }} \
  vip_{{ ers_instance }} 

{#
    set rules for coloaction
#}
colocation col_sap_{{ sap.sid }}_no_both -5000: SAP-{{ ers_instance }} SAP-{{ ascs_instance }}

{#
    Set general properties
#}
property cib-bootstrap-options: \
  cluster-infrastructure=corosync \  
  stonith-enabled=true \
  stonith-action=off \ 
  stonith-timeout=300s \
  maintenance-mode=false \   
  last-lrm-refresh=1632815429
{% endif %}