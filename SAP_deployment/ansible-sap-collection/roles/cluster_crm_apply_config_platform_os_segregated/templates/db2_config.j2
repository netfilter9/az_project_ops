{#
  include common header to define nodes and STONITH approach
#}

primitive rsc_st_azure stonith:fence_azure_arm \
    params subscriptionId={{ subscription_id }} resourceGroup={{ resource_group }} tenantId={{ tenant_id }} login={{ app_id }} passwd={{ app_pass }} \ 
    pcmk_monitor_retries=4 pcmk_action_limit=3 power_timeout=240 pcmk_reboot_timeout=900 \ 
    op monitor interval=3600 timeout=120

{#
  Add profile cluster 
#}
primitive rsc_Db2_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} db2 \
        params instance="db2{{ sap.db.sid | lower }}" dblist="{{ sap.db.sid }}" \
        op start interval="0" timeout="130" \
        op stop interval="0" timeout="120" \
        op promote interval="0" timeout="120" \
        op demote interval="0" timeout="120" \
        op monitor interval="30" timeout="60" \
        op monitor interval="31" role="Master" timeout="60"

{# 
  Azure configure the VIP - same as Azure Load Balancer IP in the operating system 
#}
primitive rsc_ip_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} IPaddr2 \
        op monitor interval="10s" timeout="20s" \
        params ip="{{ sap.lb_ip }}"

{# 
  Configure probe port for Azure load Balancer
#}
primitive rsc_nc_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} azure-lb port=62500

{#
  Put network resources in group
#}
group g_ip_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} rsc_ip_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} rsc_nc_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }}

ms msl_Db2_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} rsc_Db2_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} \
        meta target-role="Started" notify="true"

{#
  Ensure that the network resources and DB2 master run on the same server 
#}
colocation col_db2_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} inf: g_ip_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }}:Started msl_Db2_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }}:Master

{#
  Ensure DB2 topology is running before the DB2 master
#}
order ord_db2_ip_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }} inf: msl_Db2_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }}:promote g_ip_db2{{ sap.db.sid | lower }}_{{ sap.db.sid }}:start

{#
  General configuration standards
#}
rsc_defaults rsc-options: \
        resource-stickiness=1000 \
        migration-threshold=5000

