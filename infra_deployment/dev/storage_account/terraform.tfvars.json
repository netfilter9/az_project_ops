{
  "foundation": {
    "resource_groups": [
      {
        "name": "rg-vcsi-dev-weu-sapk-001",
        "location": "westeurope",
        "lookup": true,
        "is_default": true
      }
    ],
    "networks": {
      "vnet-vcsi-dev-weu-app-001": {
        "lookup": true,
        "resource_group_name": "rg-vcsi-dev-weu-vnet-001",
        "use_inline_subnets": true,
        "address_space": [
          "10.130.96.0/23"
        ],
        "subnets": {
          "snet-vcsi-dev-weu-sapk-002": {
            "lookup": true
          }
        }
      }
    },
    "tags": {
      "Environment": "DEV"
    },
    "storage_accounts": {
      "stvcsidevweusapk001": {
        "account_tier": "Standard",
        "account_kind": "StorageV2",
        "account_replication_type": "LRS",
        "containers": {
          "archivelog": {
            "container_access_type": "private"
          },
          "daily": {
            "container_access_type": "private"
          },
          "weekly": {
            "container_access_type": "private"
          },
          "monthly": {
            "container_access_type": "private"
          },
          "annual": {
            "container_access_type": "private"
          }
        },
        "management_policy": {
          "rules": [
            {
              "name": "archivelog-rule",
              "enabled": true,
              "filter": {
                "prefix_match": [
                  "archivelog/archive"
                ],
                "blob_types": [
                  "blockBlob"
                ]
              },
              "action": {
                "base_blob": {
                  "delete_after_days_since_modification_greater_than": 14
                }
              }
            },
            {
              "name": "daily-rule",
              "enabled": true,
              "filter": {
                "prefix_match": [
                  "daily/daily"
                ],
                "blob_types": [
                  "blockBlob"
                ]
              },
              "action": {
                "base_blob": {
                  "delete_after_days_since_modification_greater_than": 14
                }
              }
            },
            {
              "name": "weekly-rule",
              "enabled": true,
              "filter": {
                "prefix_match": [
                  "weekly/weekly"
                ],
                "blob_types": [
                  "blockBlob"
                ]
              },
              "action": {
                "base_blob": {
                  "delete_after_days_since_modification_greater_than": 14
                }
              }
            },
            {
              "name": "monthly-rule",
              "enabled": true,
              "filter": {
                "prefix_match": [
                  "monthly/monthly"
                ],
                "blob_types": [
                  "blockBlob"
                ]
              },
              "action": {
                "base_blob": {
                  "delete_after_days_since_modification_greater_than": 366
                }
              }
            },
            {
              "name": "annual-rule",
              "enabled": true,
              "filter": {
                "prefix_match": [
                  "annual/annual"
                ],
                "blob_types": [
                  "blockBlob"
                ]
              },
              "action": {
                "base_blob": {
                  "delete_after_days_since_modification_greater_than": 3660
                }
              }
            }
          ]
        },
        "network_rules": {
          "netrule-01": {
            "default_action": "Deny",
            "ip_rules": [],
            "bypass": [
              "AzureServices"
            ],
            "subnets": [
              {
                "vnet": "vnet-vcsi-dev-weu-app-001",
                "subnet": "snet-vcsi-dev-weu-sapk-002"
              }
            ]
          }
        },
        "private_endpoints": {
          "pep-st-blob-vcsi-dev-weu-sapk-001": {
            "private_service_connection_name": "pep-st-blob-vcsi-dev-weu-sapk-001-connection",
            "network": {
              "subnet": "snet-vcsi-dev-weu-sapk-002",
              "vnet": "vnet-vcsi-dev-weu-app-001"
            },
            "privatelink_resource_group_name": "rg-vcsi-dev-weu-sapk-001",
            "privatelink_name": "stvcsidevweusapk001.privatelink.blob.core.windows.net",
            "subresource_names": [
              "blob"
            ]
          }
        }
      }
    }
  }
}