                    "properties": {
                        "rules": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "examples": [
                                            "rule1"
                                        ]
                                    },
                                    "enabled": {
                                        "type": "boolean",
                                        "default": true
